@article{kaced2013,
  author    = {Kaced, Tarik and Romashchenko, Andrei},
  title     = {Conditional Information Inequalities for Entropic and Almost
               Entropic Points},
  journal   = {IEEE Transactions on Information Theory},
  volume    = {59},
  number    = {11},
  pages     = {7149--7167},
  year      = {2013},
  month     = nov,
  doi       = {10.1109/TIT.2013.2274614},
  eprint    = {1207.5742},
  archivePrefix = {arXiv},
  primaryClass  = {cs.IT},
  note      = {Classifies zhangyeung1997's conditional inequality as
               $(\mathcal{I}_1)$ in a family of essentially conditional
               inequalities. Theorem 3 + Claim 1 prove essential
               conditionality: no Lagrange combination of the premises
               added to an unconditional Shannon-type inequality recovers
               $(\mathcal{I}_1)$. Theorem 5 proves $(\mathcal{I}_1)$ fails
               on $\overline{\Gamma}^*_n$, the closure of the entropic
               region.}
}


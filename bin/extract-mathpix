#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["httpx"]
# ///
"""Submit a PDF to the Mathpix API, poll until complete, and download the Markdown output.

Requires MATHPIX_APP_ID and MATHPIX_APP_KEY in the environment.

Usage:
  bin/extract-mathpix <input.pdf> <output-dir>
"""

import json
import os
import sys
import time
from pathlib import Path

import httpx

APP_ID = os.environ["MATHPIX_APP_ID"]
APP_KEY = os.environ["MATHPIX_APP_KEY"]
BASE = "https://api.mathpix.com/v3"
HEADERS = {"app_id": APP_ID, "app_key": APP_KEY}

OPTIONS = {
    "conversion_formats": {"md": True},
    "math_inline_delimiters": ["$", "$"],
    "math_display_delimiters": ["$$", "$$"],
    "include_equation_tags": True,
    "idiomatic_eqn_arrays": True,
    "rm_spaces": True,
    "enable_tables_fallback": True,
    "include_page_info": True,
}


def submit(pdf_path: Path) -> str:
    with pdf_path.open("rb") as f:
        r = httpx.post(
            f"{BASE}/pdf",
            headers=HEADERS,
            files={"file": (pdf_path.name, f, "application/pdf")},
            data={"options_json": json.dumps(OPTIONS)},
            timeout=60,
        )
    r.raise_for_status()
    return r.json()["pdf_id"]


def poll(pdf_id: str) -> dict:
    url = f"{BASE}/pdf/{pdf_id}"
    delay = 2
    while True:
        r = httpx.get(url, headers=HEADERS, timeout=30)
        r.raise_for_status()
        body = r.json()
        status = body.get("status", "?")
        pct = body.get("percent_done", "?")
        pages = f"{body.get('num_pages_completed', '?')}/{body.get('num_pages', '?')}"
        print(f"  [{pdf_id}] status={status} pct={pct} pages={pages}")
        if status in ("completed", "error"):
            return body
        time.sleep(delay)
        delay = min(delay * 1.5, 15)


def download(pdf_id: str, ext: str, out: Path) -> None:
    url = f"{BASE}/pdf/{pdf_id}.{ext}"
    r = httpx.get(url, headers=HEADERS, timeout=60)
    r.raise_for_status()
    out.write_bytes(r.content)
    print(f"  wrote {out} ({len(r.content)} bytes)")


def main(pdf_path: Path, out_dir: Path) -> None:
    out_dir.mkdir(parents=True, exist_ok=True)
    print(f"Submitting {pdf_path} ...")
    pdf_id = submit(pdf_path)
    print(f"  pdf_id={pdf_id}")
    (out_dir / "pdf_id.txt").write_text(pdf_id + "\n")

    print("Polling ...")
    result = poll(pdf_id)
    (out_dir / "status.json").write_text(json.dumps(result, indent=2))
    if result.get("status") != "completed":
        sys.exit(f"processing did not complete: {result}")

    print("Downloading formats ...")
    stem = pdf_path.stem
    for ext in ("md", "lines.json"):
        download(pdf_id, ext, out_dir / f"{stem}.mathpix.{ext}")


if __name__ == "__main__":
    if len(sys.argv) != 3:
        sys.exit(f"usage: {sys.argv[0]} <input.pdf> <output-dir>")
    main(Path(sys.argv[1]), Path(sys.argv[2]))

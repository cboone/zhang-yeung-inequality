#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["sympy"]
# ///
"""Verify the projective-plane S_F calculation on page 1445 of Zhang-Yeung 1998.

The paper states intermediate entropies and mutual informations for the four
random variables X_1, X_2, X_3, X_4 constructed from two projective planes of
order 3. It then computes

    S_F(1, 2 | 3, 4) = I(X_1; X_2) + I(X_3; X_4 | X_1) + I(X_3; X_4 | X_2)
                       - I(X_3; X_4)
                     = log_2(13/12) + 2 log_2(4/3) - log_2(13/6)
                     = -log_2(9/8)

This script checks that the stated intermediate values are internally
consistent, and that the final simplification is exact.
"""

from sympy import Rational, log, simplify, nsimplify

# Stated values from p. 1445:
I_X1_X2 = log(Rational(13, 12), 2)
H_X3 = log(13, 2)
H_X4 = log(13, 2)
H_X3X4 = log(6, 2) + log(13, 2)
H_X3_given_Xi = log(4, 2)    # H(X_3 | X_1) = H(X_3 | X_2) = H(X_4 | X_1) = H(X_4 | X_2)
H_X3X4_given_Xi = log(12, 2)  # H(X_3, X_4 | X_1) = H(X_3, X_4 | X_2)

# Derive I(X_3; X_4) from entropies:
I_X3_X4_derived = H_X3 + H_X4 - H_X3X4
I_X3_X4_stated = log(13, 2) - log(6, 2)

# Derive I(X_3; X_4 | X_i) from conditional entropies:
I_X3_X4_given_Xi_derived = 2 * H_X3_given_Xi - H_X3X4_given_Xi
I_X3_X4_given_Xi_stated = log(Rational(4, 3), 2)

# Compose S_F:
S_F = I_X1_X2 + 2 * I_X3_X4_given_Xi_derived - I_X3_X4_derived
S_F_expected = -log(Rational(9, 8), 2)

def check(name, derived, stated):
    diff = simplify(derived - stated)
    ok = diff == 0
    print(f"  {'OK' if ok else 'FAIL'}  {name}: derived={derived}, stated={stated}, diff={diff}")
    return ok

print("Verifying Zhang-Yeung 1998 projective-plane S_F calculation (p. 1445):")
ok1 = check("I(X_3; X_4)", I_X3_X4_derived, I_X3_X4_stated)
ok2 = check("I(X_3; X_4 | X_i)", I_X3_X4_given_Xi_derived, I_X3_X4_given_Xi_stated)
ok3 = check("S_F(1, 2 | 3, 4)", S_F, S_F_expected)

if all([ok1, ok2, ok3]):
    print("\nAll checks pass. The transcribed intermediate values and final")
    print("result are internally consistent.")
else:
    raise SystemExit(1)
